# Devin API (v1 sessions API - personal apk_user_* or service apk_* key)
DEVIN_API_KEY=your-devin-api-key-here
DEVIN_API_URL=https://api.devin.ai

# Devin Review API (v3 - optional, only used to READ review status for the
# dashboard; reviews themselves are auto-triggered because the repo is
# enrolled in Devin Review auto-review in the Devin app settings)
DEVIN_ORG_ID=
DEVIN_SERVICE_TOKEN=

# GitHub Configuration
TARGET_LABEL=devin-fix
# Label the dashboard lists tickets by (read live from GitHub)
CATALOG_LABEL=created by Devin
# Needs write access to the fork: read tickets, normalize PR bodies, and (on
# reset) close PRs, delete branches, recreate issues. Use `gh auth token` or a
# fine-grained PAT with Issues/Pull requests/Contents read-write on the fork.
GITHUB_TOKEN=your-github-token-here
# Optional: empty skips webhook signature verification (fine for local demos;
# the direct POST /issues trigger never needs it). If set, it MUST match the
# secret configured on the GitHub webhook, otherwise all deliveries are
# rejected with a 401. Generate one with: openssl rand -hex 20
GITHUB_WEBHOOK_SECRET=
REPO_OWNER=felixbrock
REPO_NAME=superset

# System Configuration
MAX_CONCURRENT_SESSIONS=3
MAX_RETRIES=2
POLL_INTERVAL_SECONDS=15
SESSION_TIMEOUT_SECONDS=7200
